# Application Settings
APP_NAME=DAEN_Capstone_Project
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Database Configuration
DATABASE_URL=postgresql://daen_user:daen_password@localhost:5432/daen_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=daen_db
DB_USER=daen_user
DB_PASSWORD=daen_password

# Redis Configuration (if using caching)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# API Keys (replace with actual keys)
API_KEY=your-api-key-here
EXTERNAL_API_URL=https://api.example.com
EXTERNAL_API_KEY=your-external-api-key

# AWS Configuration (if using AWS services)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# JWT Configuration (if using JWT authentication)
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ML Model Configuration
MODEL_PATH=models/trained_model.pkl
MODEL_VERSION=1.0.0

# Data Paths
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_EXTERNAL_PATH=data/external

# Testing
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5432/test_db

# Miscellaneous
TIMEZONE=America/New_York
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
